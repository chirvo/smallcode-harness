{
  "name": "@earendil-works/smallcode-harness",
  "version": "0.1.0",
  "description": "Small-model compensations for pi — ported from SmallCode's agent harness",
  "keywords": ["pi-package", "smallcode", "small-models", "coding-agent", "local-llm"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chirvo/smallcode-harness.git"
  },
  "license": "MIT",
  "type": "module",
  "peerDependencies": {
    "@earendil-works/pi-ai": "^0.75.4",
    "@earendil-works/pi-agent-core": "^0.75.4",
    "@earendil-works/pi-coding-agent": "^0.75.4",
    "@earendil-works/pi-tui": "^0.75.4",
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "lefthook": "^2.1.8",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:unit": "bun test test/unit/",
    "test:smoke": "bun test test/smoke/",
    "test:e2e": "bash test/smoke/qa.sh",
    "typecheck": "tsc --noEmit",
    "qa": "bun typecheck && bun test && bash test/smoke/qa.sh"
  },
  "pi": {
    "extensions": ["./index.ts"]
  }
}
